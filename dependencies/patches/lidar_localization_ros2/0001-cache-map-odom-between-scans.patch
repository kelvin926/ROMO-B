+void test_restamp_transform_preserves_correction()
+{
+  const auto map_to_base = ll::makeMapToBaseTransform(
+    stamp(3), "map", "base_link", pose_xyz(10.0, 0.0, 0.0));
+  const auto odom_to_base = ll::makeMapToBaseTransform(
+    stamp(3), "odom", "base_link", pose_xyz(4.0, 0.0, 0.0));
+  const auto correction = ll::composeMapToOdomTransform(
+    stamp(3), "map", "odom", map_to_base, odom_to_base);
+
+  const auto restamped = ll::restampTransform(correction, stamp(20, 50));
+  assert(restamped.header.stamp.sec == 20);
+  assert(restamped.header.stamp.nanosec == 50);
+  assert(restamped.header.frame_id == "map");
+  assert(restamped.child_frame_id == "odom");
+  assert(near(restamped.transform.translation.x, 6.0));
+  assert(near(restamped.transform.rotation.w, 1.0));
+}
+
+void test_cached_correction_does_not_counter_rotate_odom()
+{
+  const auto initial_map_to_base = ll::makeMapToBaseTransform(
+    stamp(3), "map", "base_link", pose_yaw(0.0));
+  const auto initial_odom_to_base = ll::makeMapToBaseTransform(
+    stamp(3), "odom", "base_link", pose_yaw(0.0));
+  const auto cached_correction = ll::composeMapToOdomTransform(
+    stamp(3), "map", "odom", initial_map_to_base, initial_odom_to_base);
+
+  const auto moved_odom_to_base = ll::makeMapToBaseTransform(
+    stamp(4), "odom", "base_link", pose_yaw(0.5));
+  const auto incorrect_recomputed = ll::composeMapToOdomTransform(
+    stamp(4), "map", "odom", initial_map_to_base, moved_odom_to_base);
+
+  tf2::Transform cached_tf;
+  tf2::Transform moved_odom_tf;
+  tf2::Transform incorrect_tf;
+  tf2::fromMsg(cached_correction.transform, cached_tf);
+  tf2::fromMsg(moved_odom_to_base.transform, moved_odom_tf);
+  tf2::fromMsg(incorrect_recomputed.transform, incorrect_tf);
+
+  assert(near(tf2::getYaw((cached_tf * moved_odom_tf).getRotation()), 0.5));
+  assert(near(tf2::getYaw(incorrect_tf.getRotation()), -0.5));
+}
