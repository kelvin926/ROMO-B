+void test_correction_gate_rejects_a_distant_corridor_match()
+{
+  auto params = default_params();
+  params.enable_correction_rejection_gate = true;
+  params.correction_rejection_max_translation_m = 1.5;
+  params.correction_rejection_max_yaw_deg = 15.0;
+
+  auto input = default_input();
+  input.fitness_score = 0.5;
+  input.correction_translation_m = 8.0;
+
+  auto gate = ll::evaluateMeasurementGate(params, input);
+  assert(gate.correction_rejection_gate_active);
+  assert(gate.reject_measurement);
+  assert(gate.status_message == "registration_correction_over_limit_rejected");
+
+  input.correction_translation_m = 0.2;
+  input.correction_yaw_deg = 18.0;
+  gate = ll::evaluateMeasurementGate(params, input);
+  assert(gate.correction_rejection_gate_active);
+  assert(gate.reject_measurement);
+
+  input.correction_yaw_deg = 5.0;
+  gate = ll::evaluateMeasurementGate(params, input);
+  assert(!gate.correction_rejection_gate_active);
+  assert(!gate.reject_measurement);
+}
