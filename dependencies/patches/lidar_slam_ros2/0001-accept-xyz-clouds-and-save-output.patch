+void fromRosMsgWithOptionalIntensity(
+  const sensor_msgs::msg::PointCloud2 & message,
+  pcl::PointCloud<pcl::PointXYZI> & output)
+{
+  const bool has_intensity = std::any_of(
+    message.fields.begin(), message.fields.end(),
+    [](const sensor_msgs::msg::PointField & field) {return field.name == "intensity";});
+  if (has_intensity) {
+    pcl::fromROSMsg(message, output);
+    return;
+  }
+
+  // RKO-LIO's deskewed cloud intentionally contains XYZ only.  PCL emits one
+  // warning per conversion when such a cloud is converted directly to
+  // PointXYZI.  Preserve its geometry and provide a deterministic zero value
+  // for consumers that use PointXYZI as their registration storage type.
+  pcl::PointCloud<pcl::PointXYZ> xyz;
+  pcl::fromROSMsg(message, xyz);
+  output.clear();
+  output.reserve(xyz.size());
+  output.header = xyz.header;
+  output.width = xyz.width;
+  output.height = xyz.height;
+  output.is_dense = xyz.is_dense;
+  for (const auto & source : xyz) {
+    pcl::PointXYZI point;
+    point.x = source.x;
+    point.y = source.y;
+    point.z = source.z;
+    point.intensity = 0.0F;
+    output.push_back(point);
+  }
+  output.width = xyz.width;
+  output.height = xyz.height;
+}
+}  // namespace
