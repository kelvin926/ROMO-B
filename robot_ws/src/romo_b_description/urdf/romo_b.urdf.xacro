<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="romo_b">
  <xacro:arg name="lidar_x" default="0.25"/>
  <xacro:arg name="lidar_y" default="0.0"/>
  <xacro:arg name="lidar_z" default="0.25"/>
  <xacro:arg name="lidar_roll" default="0.0"/>
  <xacro:arg name="lidar_pitch" default="0.0"/>
  <xacro:arg name="lidar_yaw" default="0.0"/>

  <xacro:property name="body_length" value="0.756"/>
  <xacro:property name="body_width" value="0.597"/>
  <xacro:property name="body_height" value="0.342"/>
  <xacro:property name="wheelbase" value="0.323"/>
  <xacro:property name="visual_track" value="0.529"/>
  <xacro:property name="wheel_radius" value="0.103"/>
  <xacro:property name="wheel_width" value="0.075"/>

  <material name="body_blue"><color rgba="0.08 0.25 0.55 1.0"/></material>
  <material name="wheel_black"><color rgba="0.03 0.03 0.03 1.0"/></material>
  <material name="sensor_red"><color rgba="0.65 0.05 0.05 1.0"/></material>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${body_height / 2.0}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
      <material name="body_blue"/>
    </visual>
    <collision>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="55.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="2.15" ixy="0" ixz="0" iyy="3.14" iyz="0" izz="4.61"/>
    </inertial>
  </link>

  <xacro:macro name="wheel_module" params="prefix x y">
    <link name="${prefix}_steer_link">
      <visual><geometry><cylinder radius="0.035" length="0.04"/></geometry></visual>
    </link>
    <joint name="${prefix}_steer_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${prefix}_steer_link"/>
      <origin xyz="${x} ${y} ${wheel_radius - body_height / 2.0}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.523599" upper="0.523599" effort="500" velocity="2.83"/>
    </joint>
    <link name="${prefix}_wheel_link">
      <visual>
        <origin rpy="1.570796 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin rpy="1.570796 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${prefix}_steer_link"/>
      <child link="${prefix}_wheel_link"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel_module prefix="fl" x="${wheelbase / 2.0}" y="${visual_track / 2.0}"/>
  <xacro:wheel_module prefix="fr" x="${wheelbase / 2.0}" y="${-visual_track / 2.0}"/>
  <xacro:wheel_module prefix="rl" x="${-wheelbase / 2.0}" y="${visual_track / 2.0}"/>
  <xacro:wheel_module prefix="rr" x="${-wheelbase / 2.0}" y="${-visual_track / 2.0}"/>

  <!-- Placeholder until config/local/hardware.yaml records a measured transform. -->
  <link name="livox_frame">
    <visual>
      <geometry><cylinder radius="0.033" length="0.065"/></geometry>
      <material name="sensor_red"/>
    </visual>
  </link>
  <joint name="livox_joint" type="fixed">
    <parent link="base_link"/>
    <child link="livox_frame"/>
    <origin xyz="$(arg lidar_x) $(arg lidar_y) $(arg lidar_z)"
            rpy="$(arg lidar_roll) $(arg lidar_pitch) $(arg lidar_yaw)"/>
  </joint>
</robot>
