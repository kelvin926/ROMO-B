<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="1000000" name="ForwardOnlyPersistentNavigation">
      <PipelineSequence name="ForwardOnlyNavigateThroughPoses">
        <RateController hz="2.0">
          <ComputePathThroughPoses goals="{goals}" path="{path}"
            planner_id="GridBased"/>
        </RateController>
        <FollowPath path="{path}" controller_id="FollowPath"/>
      </PipelineSequence>
      <Wait wait_duration="0.5"/>
    </RecoveryNode>
  </BehaviorTree>
</root>
