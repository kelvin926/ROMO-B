<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <!--
    Autoware resolves <vehicle_model>_launch even when the planning simulator
    disables the real vehicle interface.  The live ROMO-B field launch starts
    its fail-closed vehicle adapter explicitly, so this standard contract is
    intentionally empty.
  -->
  <arg name="vehicle_id" default="$(env VEHICLE_ID default)"/>
  <arg name="raw_vehicle_cmd_converter_param_path" default=""/>
  <arg name="initial_engage_state" default="false"/>
</launch>
